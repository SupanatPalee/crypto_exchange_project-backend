# Application
PORT=3000
NODE_ENV=development

# Database
# --- กรณีรัน docker-compose (สร้าง container ใหม่) ใช้ค่าด้านล่างนี้ ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=crypto
DB_PASSWORD=crypto_secret
DB_NAME=crypto_exchange
# (user/password ตรงกับใน docker-compose: POSTGRES_USER, POSTGRES_PASSWORD)
#
# --- กรณีใช้ pgvector หรือ PostgreSQL ตัวอื่นอยู่แล้ว ใช้ user/password ของตัวนั้น ---
# DB_USERNAME=postgres
# DB_PASSWORD=รหัสของ postgres ใน container นั้น

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Access token (short-lived). Examples: 15m, 1h
JWT_EXPIRES_IN=15m
# Refresh token (long-lived). Examples: 7d, 30d
JWT_REFRESH_EXPIRES_IN=7d
